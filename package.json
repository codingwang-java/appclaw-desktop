{
  "name": "appclaw",
  "version": "0.5.5",
  "description": "Desktop Agent - 对话式 AI 桌面助手",
  "main": "dist-electron/main.js",
  "author": "AppClaw",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/codingwang-java/appclaw-desktop.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@modelcontextprotocol/sdk": "^1.5.0",
    "electron-updater": "^6.6.0",
    "jszip": "^3.10.1",
    "openai": "^4.77.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv-keywords": "^5.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "zustand": "^5.0.3"
  },
  "build": {
    "appId": "com.appclaw.desktop",
    "productName": "AppClaw",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "mcp-servers/**",
      "node_modules/@electric-sql/pglite/**"
    ],
    "files": [
      "dist/**",
      "dist-electron/**",
      "mcp-servers/**",
      "resources/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "sign": false
    },
    "publish": {
      "provider": "github",
      "owner": "codingwang-java",
      "repo": "appclaw-desktop"
    }
  }
}
